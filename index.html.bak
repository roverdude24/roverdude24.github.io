<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="Official portfolio of Lâm Vinh, Film Director and Visual Artist. Directing cinematic music videos and commercials with cutting-edge visual design.">
<title>LAMVINH — Film Director & Visual Artist</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800;900&family=Inter:wght@300;400;500;600&family=Space+Grotesk:wght@400;500;700&family=Instrument+Serif:ital,wght@0,400;1,400&display=swap" rel="stylesheet">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  html {
    scroll-behavior: smooth;
  }

  body {
    background: #ffffff;
    color: #1a1a1a;
    font-family: 'Stack Sans Text', sans-serif;
    font-weight: 400;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    min-height: 100vh;
  }

  /* Film grain overlay */
  body::after {
    content: '';
    position: fixed;
    top: 0; left: 0; width: 100%; height: 100%;
    pointer-events: none;
    z-index: 9999;
    opacity: 0.018;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }

  /* SIDEBAR */
  .sidebar {
    position: fixed;
    top: 0;
    left: 0;
    width: 280px;
    height: 100vh;
    background: #fbfbfb;
    border-right: 1px solid #f0f0f0;
    padding: 40px 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    gap: 24px;
    z-index: 100;
  }

  .profile-pic {
    width: 132px;
    height: 132px;
    border-radius: 50%;
    border: none;
    object-fit: cover;
    display: block;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .profile-pic:hover {
    transform: scale(1.05);
  }

  .sidebar .name {
    font-family: 'Instrument Serif', serif;
    font-weight: 400;
    font-size: 36px;
    letter-spacing: -0.5px;
    color: #1a1a1a;
    text-align: center;
    line-height: 1;
    margin-top: 8px;
    text-transform: uppercase;
  }

  .sidebar .title {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #c0392b;
    text-align: center;
    line-height: 1.4;
  }

  .sidebar .divider {
    width: 30px;
    height: 1px;
    background: #c0392b;
    opacity: 0.3;
    margin: 8px 0;
  }

  .sidebar-contact-info {
    margin-top: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
    text-align: center;
    align-items: center;
  }

  .sidebar-contact-label {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #c0392b;
    margin-bottom: 4px;
  }

  .sidebar-contact-info a {
    color: #666;
    text-decoration: none;
    font-size: 13px;
    font-family: 'Stack Sans Text', sans-serif;
    transition: color 0.2s ease;
    position: relative;
    padding-bottom: 2px;
  }

  .sidebar-contact-info a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0;
    height: 1px;
    background-color: #c0392b;
    transition: all 0.3s ease;
    transform: translateX(-50%);
  }

  .sidebar-contact-info a:hover {
    color: #c0392b;
  }

  .sidebar-contact-info a:hover::after {
    width: 80%;
  }

  .sidebar .sidebar-footer {
    margin-top: auto;
    font-family: 'Stack Sans Text', sans-serif;
    font-weight: 400;
    font-size: 10px;
    color: #999;
    text-align: center;
    letter-spacing: 0.5px;
    padding-top: 40px;
  }

  /* CONTENT */
  .content {
    margin-left: 280px;
    padding: 64px 80px;
    min-height: 100vh;
  }

  /* SECTIONS */
  .section {
    margin-bottom: 96px;
  }

  .section:last-child {
    margin-bottom: 64px;
  }

  .section-heading {
    font-family: 'Instrument Serif', serif;
    font-weight: 400;
    font-size: 36px;
    text-transform: uppercase;
    color: #1a1a1a;
    letter-spacing: 1.5px;
    margin-bottom: 36px;
    text-align: left;
  }

  .section-heading::before {
    content: '';
    display: none;
  }

  /* ABOUT & EXPERIENCE GRID */
  .about-exp-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
  }

  .about-col, .exp-col {
    min-width: 0;
  }

  .about-text {
    font-family: 'Stack Sans Text', sans-serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 1.85;
    color: #2c2c2c;
    margin-bottom: 24px;
  }

  .about-text:last-child {
    margin-bottom: 0;
  }

  .experience-list {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .exp-item {
    display: block;
    padding-bottom: 24px;
    border-bottom: 1px solid #f2f2f2;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .exp-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .exp-item:hover {
    transform: translateX(6px);
  }

  .exp-item:hover h3 {
    color: #c0392b;
  }

  .exp-date {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 500;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #999;
    margin-bottom: 6px;
    line-height: 1.4;
  }

  .exp-body {
    width: 100%;
  }

  .exp-body h3 {
    font-family: 'Instrument Serif', serif;
    font-weight: 800;
    font-size: 22px;
    color: #1a1a1a;
    margin-bottom: 4px;
    transition: color 0.3s ease;
  }

  .exp-body .exp-role {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 500;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #c0392b;
    margin-bottom: 8px;
  }

  .exp-body .exp-desc {
    font-family: 'Stack Sans Text', sans-serif;
    font-weight: 400;
    font-size: 14px;
    color: #555555;
    line-height: 1.6;
  }

  /* TRUSTED BY */
  .trusted-strip {
    margin-top: 16px;
    background: #fafafa;
    border: 1px solid #f0f0f0;
    border-radius: 6px;
    padding: 40px 32px;
  }

  .trusted-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 24px 20px;
    align-items: center;
    justify-items: center;
  }

  .trusted-grid img {
    width: 100%;
    max-width: 140px;
    height: 48px;
    object-fit: contain;
    filter: grayscale(100%) opacity(35%);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .trusted-grid .logo-wide {
    max-width: 160px;
    height: 56px;
  }

  .trusted-grid img:hover {
    filter: grayscale(0%) opacity(100%);
    transform: scale(1.08);
  }

  /* SHOWREEL */
  .showreel-video {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 4px;
    display: block;
    background: #000000;
    overflow: hidden;
    border: 1px solid #e5e5e5;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .showreel-video:hover {
    border-color: #c0392b;
    box-shadow: 0 24px 48px rgba(192, 57, 43, 0.12);
  }

  /* BUTTONS */
  .showreel-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: #c0392b;
    color: #ffffff;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 500;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 2px;
    padding: 14px 28px;
    border-radius: 4px;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    margin-top: 24px;
    border: 1px solid transparent;
    box-shadow: 0 4px 12px rgba(192, 57, 43, 0.15);
  }

  .showreel-btn:hover {
    background: #1a1a1a;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
  }

  .showreel-btn .play-icon {
    width: 14px;
    height: 14px;
    fill: currentColor;
    transition: transform 0.3s ease;
  }

  .showreel-btn:hover .play-icon {
    transform: scale(1.2);
  }

  .back-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: transparent;
    color: #1a1a1a;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 500;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    padding: 12px 24px;
    border: 1px solid #e0e0e0;
    border-radius: 4px;
    text-decoration: none;
    transition: all 0.3s ease;
    margin-top: 24px;
  }

  .back-btn:hover {
    background: #1a1a1a;
    color: #ffffff;
    border-color: #1a1a1a;
    transform: translateY(-2px);
  }

  /* Fade-in animation styling */
  .fade-in {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform, opacity;
  }

  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* CUSTOM SCROLLBAR (Minimalist) */
  ::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }
  ::-webkit-scrollbar-track {
    background: #ffffff;
  }
  ::-webkit-scrollbar-thumb {
    background: #e0e0e0;
    border-radius: 3px;
    transition: background 0.2s ease;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #c0392b;
  }

  /* RESPONSIVE DESIGN */
  @media (max-width: 1200px) {
    .content {
      padding: 48px 56px;
    }
    .about-exp-grid {
      gap: 48px;
    }
    .trusted-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (max-width: 900px) {
    .sidebar {
      position: relative;
      width: 100%;
      height: auto;
      padding: 40px 24px;
      gap: 24px;
      border-right: none;
      border-bottom: 1px solid #f0f0f0;
    }

    .sidebar .sidebar-footer {
      margin-top: 32px;
      padding-top: 16px;
    }

    .content {
      margin-left: 0;
      padding: 48px 24px;
    }

    .section {
      margin-bottom: 64px;
    }

    .about-exp-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .exp-item {
      padding-bottom: 20px;
    }

    .trusted-strip {
      padding: 32px 20px;
    }

    .trusted-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 20px 16px;
    }
  }

  @media (max-width: 600px) {
    .trusted-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px 12px;
    }
    .section-heading {
      font-size: 28px;
    }
  }
</style>
</head>
<body>

<!-- SIDEBAR -->
<aside class="sidebar">
  <img src="assets/media/github-avatar.png" alt="Lâm Vinh" class="profile-pic">
  <h1 class="name">LAMVINH</h1>
  <div class="title">Film Director<br>Visual Artist</div>
  <div class="divider"></div>
  <div class="sidebar-contact-info">
    <div class="sidebar-contact-label">Contact</div>
    <a href="mailto:vinh.walter@gmail.com">vinh.walter@gmail.com</a>
    <a href="https://instagram.com/vinhiam" target="_blank">@vinhiam</a>
    <a href="https://vimeo.com/vinhwalter" target="_blank">Vimeo</a>
    <a href="https://linkedin.com/in/vinhwalter" target="_blank">LinkedIn</a>
    <a href="https://vinhlam.com" target="_blank">vinhlam.com</a>
  </div>
  <div class="sidebar-footer">© 2026 Lâm Vinh</div>
</aside>

<!-- CONTENT -->
<main class="content">

  <!-- ABOUT -->
  <!-- EXPERIENCE -->
  <!-- SERVICES -->
  <!-- TRUSTED BY -->
  <!-- SHOWREEL -->
  <!-- CONTACT -->
  


<section class="section fade-in" id="trusted">
    <h2 class="section-heading">Trusted By</h2>
    <div class="trusted-strip">
      <div class="trusted-grid">
        <img src="assets/media/image10.png" alt="Brand">
        <img src="assets/media/image11.png" alt="Bia Saigon" class="logo-wide">
        <img src="assets/media/image12.png" alt="Brand">
        <img src="assets/media/image13.png" alt="Closeup" class="logo-wide">
        <img src="assets/media/image15.png" alt="ThiênLong" class="logo-wide">
        <img src="assets/media/image16.png" alt="Brand">
        <img src="assets/media/image17.png" alt="Brand">
        <img src="assets/media/image18.png" alt="Ajinomoto" class="logo-wide">
        <img src="assets/media/image19.png" alt="Brand">
        <img src="assets/media/image20.png" alt="Brand">
        <img src="assets/media/image21.png" alt="Brand">
        <img src="assets/media/image22.png" alt="Brand">
        <img src="assets/media/image7.png" alt="Brand">
        <img src="assets/media/image8.png" alt="Brand">
        <img src="assets/media/image9.png" alt="Brand">
      </div>
    </div>
  </section>

  <section class="section fade-in" id="about-exp">
    <div class="about-exp-grid">
      <div class="about-col">
        <h2 class="section-heading">About Me</h2>
        <p class="about-text">
          Lâm Vinh, a skilled director and visual artist, brings a wealth of experience to every project. With a strong background in World building and Visual direction, Vinh has directed hypebeast Music Videos for artists and created standout video ads for brands like Beck's Ice, Lay's, Closeup, PNJ, FIFA Online, Bia Saigon, Selsun, LOF Malto, Prospan, Milo, Yes Mom, and Maybelline.
        </p>
        <p class="about-text">
          Now on a mission to bring generative tools into production in ways that actually hold up on set and in post. Still directing. Just with sharper tools.
        </p>
        <a href="#showreel" class="showreel-btn">
          <svg class="play-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M8 5v14l11-7z"/>
          </svg>
          Watch Showreel
        </a>
      </div>
      <div class="exp-col">
        <h2 class="section-heading">Experience</h2>
        <div class="experience-list">
          <div class="exp-item">
            <div class="exp-body">
              <div class="exp-date">Apr 2021 – Present • 5+ years</div>
              <h3>Film Director</h3>
              <div class="exp-role">Freelance</div>
              <div class="exp-desc">Music Videos, Visual Direction</div>
            </div>
          </div>
          <div class="exp-item">
            <div class="exp-body">
              <div class="exp-date">Apr 2025 – 2026</div>
              <h3>Head of AI Studio</h3>
              <div class="exp-role">Phibious</div>
              <div class="exp-desc">Creative direction, AI pipeline</div>
            </div>
          </div>
          <div class="exp-item">
            <div class="exp-body">
              <div class="exp-date">Sep 2012 – Apr 2025 • 12+ years</div>
              <h3>Visual Motion Artist</h3>
              <div class="exp-role">Freelance</div>
              <div class="exp-desc">Motion graphics, VFX</div>
            </div>
          </div>
          <div class="exp-item">
            <div class="exp-body">
              <div class="exp-date">Sep 2019 – Feb 2021</div>
              <h3>Senior Graphic Designer</h3>
              <div class="exp-role">HypeAsia</div>
              <div class="exp-desc">Key visuals</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


<section class="section fade-in" id="showreel">
    <h2 class="section-heading">Showreel</h2>
    <video class="showreel-video" controls muted playsinline preload="metadata">
      <source src="assets/media/VAG5-EsV664.mp4" type="video/mp4">
    </video>
    <a href="#about-exp" class="back-btn">← Back to About</a>
  </section>

</main>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const faders = document.querySelectorAll('.fade-in');
  const appearOptions = {
    threshold: 0.1,
    rootMargin: "0px 0px -50px 0px"
  };
  
  const appearOnScroll = new IntersectionObserver((entries, observer) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, appearOptions);

  faders.forEach(fader => {
    appearOnScroll.observe(fader);
  });
});
</script>

</body>
</html>
